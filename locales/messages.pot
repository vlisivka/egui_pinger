#. Section 1: No internet
#: scripts/../src/ui/system_tools.rs:424 scripts/../src/ui/system_tools.rs:424 scripts/../src/ui/system_tools.rs:424
msgid "1. Internet is completely down"
msgstr ""

#: scripts/../src/ui/system_tools.rs:425 scripts/../src/ui/system_tools.rs:425 scripts/../src/ui/system_tools.rs:425
msgid "If you cannot access any website or service:"
msgstr ""

#: scripts/../src/ui/system_tools.rs:426 scripts/../src/ui/system_tools.rs:426 scripts/../src/ui/system_tools.rs:426
msgid "  • Run 'Network Interfaces' — check if your adapter has an IP address. If no IP is assigned, DHCP may have failed."
msgstr ""

#: scripts/../src/ui/system_tools.rs:427 scripts/../src/ui/system_tools.rs:427 scripts/../src/ui/system_tools.rs:427
msgid "  • Run 'Routing Table' — look for a 'default' route. If missing, the system doesn't know how to reach the internet."
msgstr ""

#: scripts/../src/ui/system_tools.rs:428 scripts/../src/ui/system_tools.rs:428 scripts/../src/ui/system_tools.rs:428
msgid "  • Run 'DNS Lookup (google.com)' — if this fails but pinging 8.8.8.8 works in the main window, you have a DNS problem, not a connection problem."
msgstr ""

#. Section 2: Intermittent connectivity
#: scripts/../src/ui/system_tools.rs:432 scripts/../src/ui/system_tools.rs:432 scripts/../src/ui/system_tools.rs:432
msgid "2. Connection drops or is unstable"
msgstr ""

#: scripts/../src/ui/system_tools.rs:433 scripts/../src/ui/system_tools.rs:433 scripts/../src/ui/system_tools.rs:433
msgid "If the connection works sometimes but keeps cutting out:"
msgstr ""

#: scripts/../src/ui/system_tools.rs:434 scripts/../src/ui/system_tools.rs:434 scripts/../src/ui/system_tools.rs:434
msgid "  • Run 'ARP Table' — if the gateway entry shows 'FAILED' or 'INCOMPLETE', there is a problem on your local network (cable, switch, or router)."
msgstr ""

#: scripts/../src/ui/system_tools.rs:435 scripts/../src/ui/system_tools.rs:435 scripts/../src/ui/system_tools.rs:435
msgid "  • Run 'Interface Statistics' — look for high 'errors' or 'dropped' counters. These indicate hardware, driver, or cable problems."
msgstr ""

#: scripts/../src/ui/system_tools.rs:436 scripts/../src/ui/system_tools.rs:436 scripts/../src/ui/system_tools.rs:436
msgid "  • Run 'Network Manager Log' — look for repeated 'connection dropped' or 'DHCP lease expired' messages."
msgstr ""

#. Section 3: Slow internet
#: scripts/../src/ui/system_tools.rs:440 scripts/../src/ui/system_tools.rs:440 scripts/../src/ui/system_tools.rs:440
msgid "3. Internet is slow"
msgstr ""

#: scripts/../src/ui/system_tools.rs:441 scripts/../src/ui/system_tools.rs:441 scripts/../src/ui/system_tools.rs:441
msgid "If pages load slowly or VoIP calls have bad quality:"
msgstr ""

#: scripts/../src/ui/system_tools.rs:442 scripts/../src/ui/system_tools.rs:442 scripts/../src/ui/system_tools.rs:442
msgid "  • Run 'Wi-Fi Connection Status' — check signal strength. Below -70 dBm (or below 50% on Windows) causes packet loss and jitter."
msgstr ""

#: scripts/../src/ui/system_tools.rs:443 scripts/../src/ui/system_tools.rs:443 scripts/../src/ui/system_tools.rs:443
msgid "  • Run 'Available Wi-Fi Networks' — if many networks use the same channel, interference is likely. Consider switching to a less crowded channel or 5 GHz band."
msgstr ""

#: scripts/../src/ui/system_tools.rs:444 scripts/../src/ui/system_tools.rs:444 scripts/../src/ui/system_tools.rs:444
msgid "  • Run 'Listening Ports' — check if many connections are open. A torrent client or large download can saturate your bandwidth."
msgstr ""

#. Section 4: DNS problems
#: scripts/../src/ui/system_tools.rs:448 scripts/../src/ui/system_tools.rs:448 scripts/../src/ui/system_tools.rs:448
msgid "4. Websites don't open, but ping works"
msgstr ""

#: scripts/../src/ui/system_tools.rs:449 scripts/../src/ui/system_tools.rs:449 scripts/../src/ui/system_tools.rs:449
msgid "If you can ping 8.8.8.8 in the main window but cannot open websites:"
msgstr ""

#: scripts/../src/ui/system_tools.rs:450 scripts/../src/ui/system_tools.rs:450 scripts/../src/ui/system_tools.rs:450
msgid "  • Run 'DNS Configuration' — verify your DNS servers are correctly set. Common public DNS: 8.8.8.8, 1.1.1.1, 9.9.9.9."
msgstr ""

#: scripts/../src/ui/system_tools.rs:451 scripts/../src/ui/system_tools.rs:451 scripts/../src/ui/system_tools.rs:451
msgid "  • Run 'DNS Lookup (google.com)' — if it fails or returns wrong IPs, your DNS server may be down or misconfigured."
msgstr ""

#: scripts/../src/ui/system_tools.rs:453 scripts/../src/ui/system_tools.rs:453 scripts/../src/ui/system_tools.rs:453
msgid "  • Run 'DNS Cache' — check for stale entries. You can flush the cache with: ipconfig /flushdns (requires admin)."
msgstr ""

